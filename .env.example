# The port for the Express API server (Railway injects this automatically)
PORT=3000

# Optional: Set a comma-delimited list of allowed CORS domains
# E.g., ALLOWED_ORIGINS=https://my-vibe-frontend.vercel.app,* 
ALLOWED_ORIGINS=*

# Optional Proxy: Use HTTP_PROXY in production to bypass YouTube datacenter bot blocks
# E.g., HTTP_PROXY=http://user:pass@proxy.example.com:8080
HTTP_PROXY=
